# ── Database (RDS) ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:<password>@<host>.rds.amazonaws.com:5432/lele2

# ── LLM ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Object storage (S3 or MinIO) ────────────────────────────────────────────
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=lele-screenshots

# ── Optional ────────────────────────────────────────────────────────────────
TAVILY_API_KEY=
SKIP_JUDGE=false
# Token budget for extended thinking (chain-of-thought). Set to 0 to disable.
# Only applies to Sonnet/Opus models. Default: 10000
THINKING_BUDGET_TOKENS=10000

# ── Server ──────────────────────────────────────────────────────────────────
RUST_LOG=lele2_backend=debug,tower_http=info
BIND_ADDR=0.0.0.0:3001
AGENTS_DIR=./agents

# ── Frontend URL (used in Slack notifications) ──────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Slack integration (optional — disabled if SLACK_BOT_TOKEN is unset) ─────
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_APP_ID=
SLACK_VERIFICATION_TOKEN=
SLACK_MODE=socket

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=
CREDENTIAL_MASTER_KEY=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── OAuth integrations (1-click connect buttons) ────────────────────────────
# Base URL of your BACKEND (where /api/oauth/:provider/callback lives)
OAUTH_REDIRECT_BASE_URL=http://localhost:3001

# Notion — create a PUBLIC integration at https://www.notion.so/profile/integrations
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=

# HubSpot — create an app at https://developers.hubspot.com/
HUBSPOT_OAUTH_CLIENT_ID=
HUBSPOT_OAUTH_CLIENT_SECRET=

# Google — create OAuth credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Meta (Facebook) — create an app at https://developers.facebook.com/apps/
META_OAUTH_CLIENT_ID=
META_OAUTH_CLIENT_SECRET=

# Slack — reuse your Slack app credentials, or create at https://api.slack.com/apps
SLACK_OAUTH_CLIENT_ID=
SLACK_OAUTH_CLIENT_SECRET=

# ── n8n (local instance via docker-compose) ──────────────────────────────────
# Run `docker compose up -d n8n`, open http://localhost:5678,
# create an account, then Settings → n8n API → Create API key
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=
