DATABASE_URL=postgresql://lele:lele_dev_password@localhost:5432/lele_dev
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-6

# Object storage (MinIO locally, S3 in prod)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=lele-screenshots

# Optional
TAVILY_API_KEY=
SKIP_JUDGE=false

RUST_LOG=lele2_backend=debug,tower_http=info
BIND_ADDR=0.0.0.0:3001

# Path to agents/ directory relative to binary (defaults to ./agents)
AGENTS_DIR=./agents
