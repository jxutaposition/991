# ── Database (RDS) ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:<password>@<host>.rds.amazonaws.com:5432/lele2

# ── LLM ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Object storage (S3 or MinIO) ────────────────────────────────────────────
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=lele-screenshots

# ── Optional ────────────────────────────────────────────────────────────────
TAVILY_API_KEY=
SKIP_JUDGE=false

# ── Server ──────────────────────────────────────────────────────────────────
RUST_LOG=lele2_backend=debug,tower_http=info
BIND_ADDR=0.0.0.0:3001
AGENTS_DIR=./agents

# ── Frontend URL (used in Slack notifications) ──────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Slack integration (optional — disabled if SLACK_BOT_TOKEN is unset) ─────
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_APP_ID=
SLACK_VERIFICATION_TOKEN=
SLACK_MODE=socket
