{
  "type": "object",
  "required": ["sequence_name", "time_period", "contacts_enrolled"],
  "properties": {
    "sequence_name": { "type": "string" },
    "time_period": { "type": "string" },
    "contacts_enrolled": { "type": "number" },
    "sequence_data": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "touch_number": { "type": "number" },
          "subject_line": { "type": "string" },
          "angle": { "type": "string" },
          "sent": { "type": "number" },
          "delivered": { "type": "number" },
          "opened": { "type": "number" },
          "replied_positive": { "type": "number" },
          "replied_negative": { "type": "number" },
          "unsubscribed": { "type": "number" },
          "meetings_booked": { "type": "number" }
        }
      }
    },
    "segment_breakdowns": {
      "type": "object",
      "description": "Optional breakdown by industry, persona, company size, etc."
    },
    "prior_period_data": { "type": "object" }
  }
}
