{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SubjectLineOptimizerOutput",
  "type": "object",
  "required": ["variants", "recommended"],
  "properties": {
    "variants": {
      "type": "array",
      "description": "All generated subject line variants, sorted by score descending.",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["subject_line", "score", "reasoning", "char_count"],
        "properties": {
          "subject_line": {
            "type": "string",
            "description": "The subject line text."
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 10,
            "description": "Predicted open-rate score from 0 to 10 using the rubric."
          },
          "reasoning": {
            "type": "string",
            "description": "One sentence explaining the score — what it does well and/or what holds it back."
          },
          "char_count": {
            "type": "integer",
            "description": "Character count of the subject line."
          },
          "pattern_used": {
            "type": "string",
            "description": "High-performing pattern this variant leverages (e.g. 'curiosity_gap', 'trigger_reference', 'first_name', 'number_specificity', 'lowercase_peer', 'company_name')."
          }
        }
      }
    },
    "recommended": {
      "type": "object",
      "description": "The single highest-scored subject line, with an explanation of why it tops the list.",
      "required": ["subject_line", "score", "why_top"],
      "properties": {
        "subject_line": { "type": "string" },
        "score": { "type": "number" },
        "why_top": {
          "type": "string",
          "description": "2-3 sentence explanation of why this subject line is the top recommendation."
        }
      }
    }
  }
}
