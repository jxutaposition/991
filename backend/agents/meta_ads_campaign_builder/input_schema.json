{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MetaAdsCampaignBuilderInput",
  "type": "object",
  "required": ["campaign_objective", "target_audience", "budget_total", "budget_period"],
  "properties": {
    "campaign_objective": {
      "type": "string",
      "enum": ["lead_gen", "conversions", "traffic", "awareness"],
      "description": "Primary Meta campaign objective."
    },
    "target_audience": {
      "description": "ICP description as a string or structured object with firmographic and demographic attributes.",
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "job_titles": { "type": "array", "items": { "type": "string" } },
            "industries": { "type": "array", "items": { "type": "string" } },
            "company_size": { "type": "string" },
            "geographies": { "type": "array", "items": { "type": "string" } },
            "interests": { "type": "array", "items": { "type": "string" } }
          }
        }
      ]
    },
    "budget_total": {
      "type": "number",
      "minimum": 0,
      "description": "Total budget in USD for the specified period."
    },
    "budget_period": {
      "type": "string",
      "enum": ["daily", "monthly"],
      "description": "Whether budget_total is a daily or monthly figure."
    },
    "ad_copy_variants": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Optional list of pre-written ad copy variants to assign to ad sets."
    },
    "landing_page_url": {
      "type": "string",
      "format": "uri",
      "description": "Destination URL for conversion campaigns."
    },
    "pixel_id": {
      "type": "string",
      "description": "Meta Pixel ID associated with the advertiser account."
    },
    "lookalike_source": {
      "type": "string",
      "enum": ["customer_list", "pixel_purchasers"],
      "description": "Source to use when building Lookalike Audiences."
    }
  },
  "additionalProperties": false
}
