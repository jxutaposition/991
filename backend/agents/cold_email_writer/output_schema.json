{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ColdEmailWriterOutput",
  "type": "object",
  "required": ["email", "variants"],
  "properties": {
    "email": {
      "type": "object",
      "description": "Primary email — the highest-confidence version to send.",
      "required": ["subject_line", "body", "word_count", "personalization_hook", "cta"],
      "properties": {
        "subject_line": {
          "type": "string",
          "description": "Under 50 characters, no exclamation mark."
        },
        "body": {
          "type": "string",
          "description": "Full email body, under 120 words."
        },
        "word_count": {
          "type": "integer",
          "description": "Exact word count of the body (excluding subject line)."
        },
        "personalization_hook": {
          "type": "string",
          "description": "The specific trigger used in the first line — one sentence describing the source (e.g. 'Series B funding announcement Feb 2026')."
        },
        "cta": {
          "type": "string",
          "description": "The exact call-to-action sentence used in the email."
        }
      }
    },
    "variants": {
      "type": "array",
      "description": "2 A/B variants with different subject lines and slightly varied first lines for split testing.",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "required": ["subject_line", "body"],
        "properties": {
          "subject_line": { "type": "string" },
          "body": { "type": "string" },
          "word_count": { "type": "integer" },
          "variant_label": {
            "type": "string",
            "enum": ["A", "B"],
            "description": "A/B test label."
          }
        }
      }
    }
  }
}
