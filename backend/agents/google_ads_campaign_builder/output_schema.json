{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GoogleAdsCampaignBuilderOutput",
  "type": "object",
  "required": [
    "campaign_structure",
    "ad_groups",
    "global_negative_keywords",
    "rsa_structure",
    "quality_score_optimizations",
    "launch_sequence",
    "estimated_cpc_range"
  ],
  "properties": {
    "campaign_structure": {
      "type": "object",
      "required": ["type", "bidding_strategy", "daily_budget"],
      "properties": {
        "type": {
          "type": "string",
          "description": "Campaign type (e.g., 'Search', 'Performance Max', 'Display')."
        },
        "bidding_strategy": {
          "type": "string",
          "description": "Initial and planned bidding strategy with transition triggers."
        },
        "daily_budget": {
          "type": "number",
          "description": "Daily budget in USD derived from monthly budget."
        }
      }
    },
    "ad_groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "theme", "keywords", "negative_keywords"],
        "properties": {
          "name": { "type": "string" },
          "theme": {
            "type": "string",
            "description": "Single-sentence description of what this ad group targets."
          },
          "keywords": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["keyword", "match_type"],
              "properties": {
                "keyword": { "type": "string" },
                "match_type": {
                  "type": "string",
                  "enum": ["exact", "phrase", "broad"]
                }
              }
            }
          },
          "negative_keywords": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Ad-group-level negative keywords specific to this theme."
          }
        }
      }
    },
    "global_negative_keywords": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Campaign-level negative keywords applied across all ad groups."
    },
    "rsa_structure": {
      "type": "object",
      "required": ["pinned_headlines", "descriptions", "extensions"],
      "properties": {
        "pinned_headlines": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["position", "text", "pinned"],
            "properties": {
              "position": { "type": "integer", "minimum": 1, "maximum": 15 },
              "text": { "type": "string" },
              "pinned": { "type": "boolean" }
            }
          }
        },
        "descriptions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["position", "text"],
            "properties": {
              "position": { "type": "integer", "minimum": 1, "maximum": 4 },
              "text": { "type": "string" }
            }
          }
        },
        "extensions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "values"],
            "properties": {
              "type": { "type": "string" },
              "values": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "quality_score_optimizations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Specific actions to improve Quality Score for the primary keywords."
    },
    "launch_sequence": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Ordered steps to set up and activate the campaign correctly."
    },
    "estimated_cpc_range": {
      "type": "string",
      "description": "Estimated cost-per-click range for the primary keyword themes (e.g., '$6–$14')."
    }
  },
  "additionalProperties": false
}
