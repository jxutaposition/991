{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CRMUpdaterInput",
  "type": "object",
  "required": ["source_session_id"],
  "properties": {
    "contacts_to_upsert": {
      "type": "array",
      "description": "Contacts to create or update in the CRM.",
      "items": {
        "type": "object",
        "required": ["name", "email", "company_domain"],
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "title": { "type": "string" },
          "company_name": { "type": "string" },
          "company_domain": { "type": "string" },
          "linkedin_url": { "type": "string", "format": "uri" },
          "phone": { "type": "string" },
          "notes": { "type": "string", "description": "Free-text research notes or context to add to the contact record." },
          "pipeline_stage": {
            "type": "string",
            "enum": ["Identified", "Contacted", "Engaged", "Meeting Scheduled", "Opportunity", "Closed Won", "Closed Lost"],
            "description": "CRM pipeline stage to set on the contact."
          }
        }
      }
    },
    "activities_to_log": {
      "type": "array",
      "description": "Activities to log against existing or newly created contact records.",
      "items": {
        "type": "object",
        "required": ["contact_email", "activity_type", "description", "timestamp"],
        "properties": {
          "contact_email": { "type": "string", "format": "email" },
          "activity_type": {
            "type": "string",
            "enum": ["email_sent", "email_opened", "email_replied", "call_made", "meeting_scheduled", "meeting_completed", "note_added", "linkedin_message_sent"]
          },
          "description": { "type": "string" },
          "timestamp": { "type": "string", "description": "ISO 8601 datetime string." },
          "metadata": {
            "type": "object",
            "description": "Optional extra data (e.g. email subject, call duration).",
            "additionalProperties": true
          }
        }
      }
    },
    "source_session_id": {
      "type": "string",
      "description": "Unique identifier for the outreach session that produced this data. Used for idempotency and traceability."
    }
  },
  "additionalProperties": false
}
