          {
            "name": "queryString"
          },
          {
            "name": "body",
            "formulaText": "\"{\\n  \\\"linkedin_url\\\": \\\"/\\\",\\n  \\\"revenue_generated\\\": \\\"\" + Clay.formatForJSON({{@Total Revenue}}) + \"\\\",\\n  \\\"reactions_count\\\": \\\"\\\",\\n  \\\"comments_count\\\": \\\"\\\",\\n  \\\"post_url\\\": \\\"\\\",\\n  \\\"timestamp\\\": \\\"\\\",\\n  \\\"tag\\\": \\\"expert\\\"\\n}\""
          },
          {
            "name": "headers",
            "formulaMap": {
              "X-Api-Key": "\"R7MEfUGzJCClQJ2nD49ejXUniMz8YQZl\"",
              "Content-Type": "\"Application/json\""
            }
          },
          {
            "name": "fieldPaths"
          },
          {
            "name": "removeNull",
            "formulaText": "true"
          },
          {
            "name": "returnResponseMetadata"
          },
          {
            "name": "followRedirects",
            "formulaText": "true"
          },
          {
            "name": "followRedirectsOptions|maxRedirects"
          },
          {
            "name": "responseTimeout"
          },
          {
