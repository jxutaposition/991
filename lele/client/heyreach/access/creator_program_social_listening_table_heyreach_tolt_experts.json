          },
          {
            "name": "retryOptions|maxRetries"
          },
          {
            "name": "retryOptions|statusCodesToRetry"
          },
          {
            "name": "retryOptions|errorCodesToRetry"
          }
        ],
        "conditionalRunFormulaText": "{{@Total Revenue}} && {{@Total Revenue}} !='$0.00'"
      }
