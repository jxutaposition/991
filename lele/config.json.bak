{
  "$schema": "config",
  "owner_name": "Lele",
  "owner_id": "lele",
  "owner_slack_id": "U3G9NGS5T",
  "owner_dm_channel": "D0ACERJTXJQ",
  "bot_user_id": "U0AD5GLDW9E",
  "slack_workspace_url": "https://woshi.slack.com",

  "voice": {
    "enabled": true,
    "target_channel": "D0ACERJTXJQ",
    "default_voice": "Sarah",
    "max_tokens": 500,
    "fallback_on_failure": "text_with_note"
  },

  "planning": {
    "custom_classifications": [],
    "tier3_signals": [
      "entity resolved by inference only",
      "named field not verified against access schema",
      "tool not used successfully before in log.md",
      "prior log entry has plan_revised or context_gap",
      "multiple plausible interpretations",
      "irreversible action",
      "factual claims not verified against primary source"
    ],
    "ambiguity_handling": "ask_owner",
    "access_escalation_retries_before_asking": 3
  },

  "proactive": {
    "cooldown_hours": 24,
    "max_per_thread_per_day": 1,
    "stale_thread_nudge_after_hours": 24,
    "message_style": "update_plus_single_question",
    "thread_priority_weights": {
      "high": 3,
      "medium": 2,
      "low": 1
    }
  },

  "escalation": {
    "retry_hours": 4,
    "max_retries": 1,
    "blocker_format": "what_why_need",
    "visibility_format": "what_result"
  },

  "client_comms": {
    "max_words_direct_answer": 50,
    "lead_with": "answer",
    "cite_past_work": true,
    "engagement_hook": true,
    "feedback_footer": false,
    "duplicate_question_gate": "strict",
    "untagged_message_processing": "extract_facts_no_reply"
  },

  "briefing": {
    "enabled": true,
    "time": "09:30",
    "timezone": "America/New_York",
    "lookback_hours": 24,
    "sections": ["blocked_on_client", "blocked_on_owner", "blocked_on_agent"],
    "thread_description_format": "noun_verb"
  },

  "meeting_sync": {
    "enabled": true,
    "source": {
      "type": "fathom",
      "gmail_query": "from:fathom subject:heyreach"
    },
    "schedule": {
      "day": "tuesday",
      "time": "09:30",
      "timezone": "America/New_York"
    },
    "notion_page_id": "2fcc1c45-c9a0-80fc-a2c7-cf85b0a9c66f",
    "transcript_chunk_size": 2000,
    "require_source_quotes": true
  },

  "documentation": {
    "context_format": "[YYYY-MM-DD source(url)] fact.",
    "context_compression_threshold_words": 200,
    "thread_archival_requires_date": true,
    "log_metadata_fields": ["classification", "tier", "autonomous", "escalation_reason", "outcome", "plan_revised", "context_gaps", "feedback"]
  },

  "analysis": {
    "error_normalization": "flag_all",
    "report_frequency": "weekly",
    "dead_read_threshold_pct": 30,
    "reread_threshold_pct": 20
  },

  "brainstorming": {
    "default_style": "options_with_tradeoffs",
    "cite_past_work": true,
    "decide_for_client": false
  },

  "goal": {
    "metric": "client_to_owner_message_ratio",
    "target": "2:1",
    "track_in": "progress/metrics.md"
  }
}
